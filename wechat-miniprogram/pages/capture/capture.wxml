<view class="page">
  <view class="hero">
    <text class="title">拍照识衣</text>
    <text class="sub">选择单品照或全身照，系统会按队列逐张处理。</text>
  </view>

  <view class="ai-banner {{aiReady ? 'ready' : 'warn'}}">
    <view>
      <text class="ai-title">{{aiStatus}}</text>
      <text class="ai-detail">{{aiStatusDetail}}</text>
    </view>
    <button class="refresh-btn" bindtap="refreshAiStatus">刷新</button>
  </view>

  <view class="mode-row">
    <button class="mode {{mode == 'single' ? 'active' : ''}}" data-mode="single" bindtap="setMode">单品</button>
    <button class="mode {{mode == 'outfit' ? 'active' : ''}}" data-mode="outfit" bindtap="setMode">整套</button>
  </view>

  <view class="options">
    <view class="option-row">
      <text>识别模式</text>
      <picker range="{{aiModes}}" value="{{aiModeIndex}}" bindchange="changeAiMode">
        <view class="select">{{aiModeLabel}}</view>
      </picker>
    </view>
    <view class="option-row">
      <text>生成 AI 单品图</text>
      <switch checked="{{generateFlat}}" color="#c02655" bindchange="toggleGenerateFlat"></switch>
    </view>
  </view>

  <button class="primary" loading="{{processing}}" disabled="{{processing}}" bindtap="chooseImages">
    {{processing ? '正在处理队列' : '选择图片 / 拍照'}}
  </button>

  <view wx:if="{{queue.length}}" class="queue">
    <text class="section-title">处理队列</text>
    <block wx:for="{{queue}}" wx:key="id">
      <view class="queue-item">
        <image class="queue-img" src="{{item.path}}" mode="aspectFill"></image>
        <view class="queue-copy">
          <text class="queue-name">{{item.name}}</text>
          <text class="queue-status {{item.error ? 'error' : ''}}">{{item.status}}</text>
        </view>
      </view>
    </block>
  </view>

  <view wx:if="{{pendingGarments.length}}" class="results">
    <view class="section-head">
      <text class="section-title">待加入衣橱</text>
      <text class="muted">{{pendingGarments.length}} 件</text>
    </view>
    <view class="grid">
      <block wx:for="{{pendingGarments}}" wx:key="id">
        <view class="card">
          <image wx:if="{{item.imagePath}}" class="garment-img" src="{{item.imagePath}}" mode="aspectFit"></image>
          <view wx:else class="visual" style="background: {{item.colorHex}};"></view>
          <text class="name">{{item.name}}</text>
          <text class="meta">{{item.category}} · {{item.primaryColor}}</text>
          <text class="tags">{{item.tagsText}}</text>
        </view>
      </block>
    </view>
    <button class="primary confirm" bindtap="confirmGarments">加入衣橱</button>
  </view>
</view>
