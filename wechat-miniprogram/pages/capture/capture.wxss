.page {
  min-height: 100vh;
  padding: 30rpx 26rpx 190rpx;
  box-sizing: border-box;
  background: #fffaf7;
}

.hero {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 20rpx;
  margin-bottom: 24rpx;
}

.title {
  display: block;
  font-size: 46rpx;
  font-weight: 850;
  color: #171014;
}

.sub,
.muted,
.meta,
.tags {
  color: #81767c;
}

.sub {
  display: block;
  margin-top: 10rpx;
  font-size: 26rpx;
  line-height: 1.55;
}

.hero-badge {
  flex: 0 0 auto;
  display: flex;
  gap: 8rpx;
  padding-top: 8rpx;
}

.hero-badge text {
  padding: 8rpx 14rpx;
  border-radius: 999rpx;
  color: #7d2c4a;
  background: #ffe8ef;
  font-size: 22rpx;
  font-weight: 800;
}

.ai-banner {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 18rpx;
  margin-bottom: 22rpx;
  padding: 22rpx;
  border-radius: 30rpx;
  border: 1rpx solid #eadcf8;
  background: #f8f0ff;
  box-shadow: 0 14rpx 38rpx rgba(90, 62, 48, 0.06);
}

.ai-banner.ready {
  border-color: #d9eadf;
  background: #f1fbf4;
}

.ai-banner.warn {
  border-color: #f1d7df;
  background: #fff0f4;
}

.ai-title {
  display: block;
  color: #171014;
  font-size: 28rpx;
  font-weight: 850;
}

.ai-detail {
  display: block;
  margin-top: 6rpx;
  color: #766a72;
  font-size: 23rpx;
  line-height: 1.45;
}

.refresh-btn {
  flex: 0 0 auto;
  min-width: 108rpx;
  height: 58rpx;
  line-height: 58rpx;
  padding: 0 18rpx;
  border-radius: 22rpx;
  color: #c02655;
  background: #ffffff;
  font-size: 23rpx;
  font-weight: 800;
}

.mode-row {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 14rpx;
  margin-bottom: 18rpx;
}

.mode,
.primary,
.ghost {
  height: 86rpx;
  line-height: 86rpx;
  border-radius: 28rpx;
  font-size: 29rpx;
  font-weight: 800;
}

.mode {
  color: #171014;
  background: #ffffff;
  border: 1rpx solid #efe4df;
}

.mode.active,
.primary {
  color: #ffffff;
  background: #c02655;
}

.mode[disabled],
.primary[disabled] {
  opacity: 0.72;
}

.ghost {
  margin-top: 18rpx;
  color: #5f555a;
  background: #f7f2ef;
}

.options,
.queue,
.results {
  margin-top: 22rpx;
  padding: 22rpx;
  border-radius: 30rpx;
  background: #ffffff;
  border: 1rpx solid #f0e6e1;
  box-shadow: 0 16rpx 42rpx rgba(90, 62, 48, 0.07);
}

.option-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 20rpx;
  min-height: 86rpx;
  font-size: 27rpx;
}

.option-row:first-child {
  border-bottom: 1rpx solid #f5eeeb;
}

.option-title {
  display: block;
  color: #171014;
  font-weight: 850;
}

.option-sub {
  display: block;
  margin-top: 6rpx;
  color: #81767c;
  font-size: 22rpx;
  line-height: 1.35;
}

.select {
  min-width: 132rpx;
  padding: 12rpx 20rpx;
  border-radius: 22rpx;
  background: #f7f2ef;
  text-align: center;
  font-weight: 800;
}

.section-head {
  display: flex;
  justify-content: space-between;
  gap: 18rpx;
  margin-bottom: 16rpx;
}

.section-title {
  font-size: 31rpx;
  font-weight: 850;
}

.queue-item {
  display: flex;
  gap: 18rpx;
  padding: 18rpx 0;
  border-top: 1rpx solid #f4eeeb;
}

.queue-item:first-of-type {
  border-top: 0;
}

.queue-img {
  width: 108rpx;
  height: 108rpx;
  border-radius: 24rpx;
  background: #f8f0ea;
}

.queue-copy {
  flex: 1;
  display: flex;
  flex-direction: column;
  justify-content: center;
  gap: 8rpx;
  min-width: 0;
}

.queue-line {
  display: flex;
  justify-content: space-between;
  gap: 16rpx;
}

.queue-name {
  font-weight: 850;
}

.queue-percent {
  color: #c02655;
  font-size: 23rpx;
  font-weight: 850;
}

.queue-status {
  color: #7b579d;
  font-size: 24rpx;
  line-height: 1.35;
}

.queue-status.error,
.error-box {
  color: #c02655;
}

.mini-link {
  align-self: flex-start;
  width: 190rpx;
  margin: 0;
  padding: 0 18rpx;
  height: 50rpx;
  line-height: 50rpx;
  border-radius: 18rpx;
  color: #c02655;
  background: #fff0f4;
  font-size: 22rpx;
  font-weight: 800;
}

.error-box {
  display: block;
  margin-top: 12rpx;
  padding: 16rpx;
  border-radius: 20rpx;
  background: #fff0f4;
  font-size: 23rpx;
  line-height: 1.45;
}

.grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 16rpx;
}

.card {
  min-width: 0;
  padding: 16rpx;
  border-radius: 26rpx;
  background: #fbf7f4;
}

.image-shell {
  position: relative;
}

.garment-img,
.visual {
  width: 100%;
  height: 210rpx;
  border-radius: 22rpx;
  background: #f8f0ea;
}

.image-pill {
  position: absolute;
  left: 12rpx;
  bottom: 12rpx;
  padding: 7rpx 12rpx;
  border-radius: 999rpx;
  color: #7d2c4a;
  background: rgba(255, 240, 244, 0.92);
  font-size: 20rpx;
  font-weight: 800;
}

.name {
  display: block;
  margin-top: 12rpx;
  font-size: 26rpx;
  font-weight: 850;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.meta,
.tags {
  display: block;
  margin-top: 6rpx;
  font-size: 22rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.confirm {
  margin-top: 20rpx;
}
