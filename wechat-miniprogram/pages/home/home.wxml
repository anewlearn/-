<view class="page">
  <view class="hero">
    <view>
      <text class="hello">今天想怎么搭？</text>
      <text class="sub">从现有衣橱里挑一套，或者拍一件新衣服进来。</text>
    </view>
    <button class="camera-btn" bindtap="openCapture">⌾</button>
  </view>

  <view class="today-card" bindtap="openOutfit">
    <image class="today-image" src="/assets/outfit-recommendation.png" mode="aspectFill"></image>
    <view class="today-copy">
      <view class="tag-row">
        <text class="tag scene-tag">{{today.scene}}</text>
        <text class="tag ai-tag">AI 推荐</text>
      </view>
      <text class="outfit-title">{{today.title}}</text>
      <text class="reason">{{today.reason}}</text>
      <view class="mini-strip">
        <block wx:for="{{today.garments}}" wx:key="id">
          <view class="mini-piece">
            <image wx:if="{{item.imagePath}}" src="{{item.imagePath}}" mode="aspectFit"></image>
            <view wx:else class="mini-visual {{item.visual.kind}}" style="background: {{item.colorHex}};"></view>
          </view>
        </block>
      </view>
    </view>
  </view>

  <view class="section">
    <view class="section-head">
      <text class="section-title">快捷场景</text>
      <button class="text-btn" bindtap="refreshRecommendation">换一套</button>
    </view>
    <scroll-view scroll-x class="scene-scroll" enhanced show-scrollbar="{{false}}">
      <view class="scene-line">
        <block wx:for="{{scenes}}" wx:key="*this">
          <button class="scene" data-scene="{{item}}" bindtap="openScene">{{item}}</button>
        </block>
      </view>
    </scroll-view>
  </view>

  <view class="section">
    <view class="section-head">
      <text class="section-title">最近加入</text>
      <text class="muted">{{garmentCount}} 件</text>
    </view>
    <scroll-view scroll-x class="recent-scroll" enhanced show-scrollbar="{{false}}">
      <view class="recent-line">
        <block wx:for="{{recentGarments}}" wx:key="id">
          <view class="mini-card">
            <image wx:if="{{item.imagePath}}" class="mini-img" src="{{item.imagePath}}" mode="aspectFit"></image>
            <view wx:else class="mini-visual {{item.visual.kind}}" style="background: {{item.colorHex}};"></view>
            <text class="mini-name">{{item.name}}</text>
          </view>
        </block>
      </view>
    </scroll-view>
  </view>

  <view class="overview">
    <text class="overview-main">你的衣橱里已有 {{garmentCount}} 件单品</text>
    <text class="overview-sub">其中 {{availableCount}} 件可穿，{{favoriteCount}} 件已收藏，清洗中的单品不会参与推荐。</text>
  </view>
</view>
